<% content_for :title, "部署一覧| MyApp" %>
<% content_for :description, "登録されている部署の一覧を確認できます。" %>
<% content_for :keywords, "MyApp, 部署一覧, 絞り込み" %>
<% content_for :breadcrumb do %>
  <ol>
    <li><%= link_to "ホーム", users_path %></li>
    <li>部署一覧</li>
  </ol>
<% end %>
<% content_for :breadcrumb_list do %>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "item": {
          "@id": "<%= root_url %>",
          "name": "ホーム"
        }
      },
      {
        "@type": "ListItem",
        "position": 2,
        "item": {
          "@id": "<%= departments_url %>",
          "name": "部署一覧"
        }
      },
    ]
  }
  </script>
<% end %>
<h1>部署名</h1>
<div id="departments">
  <% @department.each do |department| %>
    <div>
      <%= link_to department.name, department_path(department.id) %>
    </div>
  <% end %> 
  <%=link_to "ユーザー一覧へ", users_path %>
</div>
