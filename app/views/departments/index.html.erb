<% content_for :title, "部署一覧| MyApp" %>
<% content_for :description, "登録されている部署の一覧を確認できます。" %>
<% content_for :keywords, "MyApp, 部署一覧, 絞り込み" %>
<% content_for :breadcrumb do %>
  <ol>
    <li><%= link_to "ホーム", users_path %></li>
    <li>部署一覧</li>
  </ol>
<% end %>
<h1>部署名</h1>
<div id="departments">
  <% @department.each do |department| %>
    <div>
      <%= link_to department.name, department_path(department.id) %>
    </div>
  <% end %> 
  <%=link_to "ユーザー一覧へ", users_path %>
</div>
