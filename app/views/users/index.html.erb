<h1>ユーザー</h1>
<%= form_with scope: "search", method: :get do |form| %>
  <div>
    <%= form.label :query_name, "名前:" %>
    <%= form.search_field :query_name , value: params.dig(:search, :query_name)%>
  </div>
  <div>
    <%= form.label :query_prefecture, "都道府県" %>
    <%= form.select :query_prefecture, User.prefectures.keys,{include_blank: '選択してください', selected: params.dig(:search, :query_prefecture)} %>
  </div>
  <div>
    <%= form.label :sort, "並び替え" %>
    <%= form.select :sort, ["生年月日 昇順", "生年月日 降順", "id 昇順", "id 降順"],{include_blank: '選択してください', selected: params.dig(:search, :sort)} %><br>

    <%= form.label :between_birthday_late, "開始日" %>
    <%= form.date_field :between_birthday_late, value: params.dig(:search, :between_birthday_late)%>
    <%= form.label :between_birthday_fast, "終了日" %>
    <%= form.date_field :between_birthday_fast,  value: params.dig(:search, :between_birthday_fast)%>
  </div>
  <div>
    <%= form.submit %>
    <%=link_to "クリア", users_path %> 
  </div>
<% end %>

<%= form_with method: :get do |form| %>
  <div>
    <%= form.label :per_page, "表示件数" %>
    <%= form.select :per_page, [10, 50, 100],{include_blank: '選択してください', selected: params.dig(:per_page)} %>
  </div>
  <%= form.submit %>
<%end%>

<div id="users">
  <% @users.each do |user| %>
    <div>
       <%= link_to user.name, user_path(user.id) %>
    </div>
  <% end %>
  <%=link_to "部署一覧へ", departments_path %>  
  <%= link_to "スキル一覧へ", skills_path %>
</div>
<%= paginate @users, window: 2, outer_window: 3 %>
<%= page_entries_info @users %>
