<% content_for :title, "スキル一覧| MyApp" %>
<% content_for :description, "登録されているスキルの一覧を確認できます。" %>
<% content_for :keywords, "MyApp, スキル一覧, 絞り込み" %>
<h1>スキル名</h1>

<div id="skills">
  <% @skills.each do |skill| %>
    <div>
      <%= link_to skill.name, skill_path(skill.id) %>
    </div>
  <% end %> 
  <%=link_to "ユーザー一覧へ", users_path %>
</div>
