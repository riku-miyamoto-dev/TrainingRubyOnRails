<% content_for :title, "スキル一覧| MyApp" %>
<% content_for :description, "登録されているスキルの一覧を確認できます。" %>
<% content_for :keywords, "MyApp, スキル一覧, 絞り込み" %>
<% content_for :breadcrumb do %>
  <ol>
    <li><%= link_to "ホーム", users_path %></li>
    <li>スキル一覧</li>
  </ol>
<% end %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "item": {
        "@id": "<%= root_url %>",
        "name": "ホーム"
      }
    },
    {
      "@type": "ListItem",
      "position": 2,
      "item": {
        "@id": "<%= skills_url %>",
        "name": "スキル一覧"
      }
    },
  ]
}
</script>
<h1>スキル名</h1>

<div id="skills">
  <% @skills.each do |skill| %>
    <div>
      <%= link_to skill.name, skill_path(skill.id) %>
    </div>
  <% end %> 
  <%=link_to "ユーザー一覧へ", users_path %>
</div>
