<% content_for :title, "スキル一覧| MyApp" %>
<% content_for :breadcrumb do %>
  <ol>
    <li><%= link_to "ホーム", admin_users_path %></li>
    <li>スキル一覧</li>
  </ol>
<% end %>
<h1>スキル名</h1>

<%= link_to "New skill", new_admin_skill_path %>
<div id="skills">
  <% @skills.each do |skill| %>
    <div>
      <%= link_to skill.name, admin_skill_path(skill.id) %>
    </div>
  <% end %> 
  <%=link_to "ユーザー一覧へ", admin_users_path(@department) %>
</div>
